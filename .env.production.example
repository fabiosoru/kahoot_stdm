# Production Environment Variables
# Copy to .env.production and update with your values

# Database - Should be in /app/data/ for Docker
DATABASE_URL="file:/app/data/prod.db"

# JWT Secret - Generate a secure random string (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"

# Node environment
NODE_ENV="production"

# Optional: Application URL (for CORS, etc)
# APP_URL="https://your-domain.com"

# Optional: Admin password (if implementing auth)
# ADMIN_PASSWORD="change-this-password"
